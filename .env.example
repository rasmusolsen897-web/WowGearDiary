# Blizzard Battle.net API
# Register an app at https://develop.battle.net/access/clients
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=

# Warcraft Logs API
# Register at https://www.warcraftlogs.com/api/clients
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=

# Raidbots (premium session — extract from browser devtools)
# 1. Log in to raidbots.com
# 2. Open DevTools → Application → Cookies → raidbots.com
# 3. Copy the value of the "connect.sid" cookie
RAIDBOTS_SESSION=
# 4. Open DevTools → Network → any request to raidbots.com → Headers
# 5. Copy the value of the "x-csrf-token" request header
RAIDBOTS_CSRF=
