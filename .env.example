# Blizzard Battle.net API
# Register an app at https://develop.battle.net/access/clients
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=

# Warcraft Logs API
# Register at https://www.warcraftlogs.com/api/clients
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=

# Raidbots automation login
# The daily Droptimizer cron can log in server-side using these.
RAIDBOTS_EMAIL=
RAIDBOTS_PASSWORD=

# Optional legacy Raidbots session auth
# If you prefer not to log in server-side, you can still provide a live raidsid cookie.
RAIDBOTS_SESSION=
# Optional legacy header from older integrations. Current live Droptimizer flow
# does not appear to require x-csrf-token for submit/poll requests.
RAIDBOTS_CSRF=

# Vercel Cron security
CRON_SECRET=

# Optional: exact Raidbots Droptimizer payloads captured from your browser network tab.
# These override the built-in defaults if Raidbots expects additional fields.
RAIDBOTS_DROPTIMIZER_RAID_JSON=
RAIDBOTS_DROPTIMIZER_MYTHIC_PLUS_JSON=

# Optional lookup overrides for better names in stored priorities
RAIDBOTS_ITEM_LOOKUP_JSON=
RAIDBOTS_SOURCE_LOOKUP_JSON=
