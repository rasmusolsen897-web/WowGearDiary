{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/droptimizer",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/droptimizer-collect",
      "schedule": "0 3,11,19 * * *"
    }
  ]
}
